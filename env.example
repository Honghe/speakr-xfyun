XF_APPID=your_appid
XF_API_KEY=your_api_key
XF_API_SECRET=your_api_secret

# Optional
LOG_LEVEL=INFO
XF_POLL_INTERVAL_SECONDS=5
XF_POLL_TIMEOUT_SECONDS=7200
XF_REQUEST_TIMEOUT_SECONDS=300
XF_MULTIPART_CHUNK_SIZE=10485760
DELETE_TEMP_FILE=true

# Optional XFYun business args
XF_POSTPROC_ON=1
XF_OUTPUT_TYPE=0
XF_ENABLE_SUBTITLE=0
XF_SMOOTHPROC=true
XF_COLLOQPROC=false
XF_LANGUAGE_TYPE=1
XF_DHW=
XF_PD=
